[layer_names]

2d_physics/layer_1="block"
2d_physics/layer_2="character"
2d_physics/layer_3="body"
2d_physics/layer_4="interaction"
2d_physics/layer_5="hitbox_player"
2d_physics/layer_6="hitbox_enemy"
2d_physics/layer_7="hitbox_environment"
2d_physics/layer_8="rough_terrain"

[rendering]

textures/canvas_textures/default_texture_filter=0
renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
2d/snap/snap_2d_transforms_to_pixel=true
